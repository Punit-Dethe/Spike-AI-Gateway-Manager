# Spike - AI Gateway Manager
# .gitignore

# ============================================
# Node.js / Electron
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.npm
.eslintcache

# ============================================
# Build outputs
# ============================================
dist/
dist-installer/
build/
out/
*.exe
*.dmg
*.AppImage
*.deb
*.rpm

# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
pip-log.txt
pip-delete-this-directory.txt

# ============================================
# IDEs and Editors
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# Environment and Config
# ============================================
.env
.env.local
.env.*.local
*.key
config/*.key
config/tokens.enc

# ============================================
# Temporary files
# ============================================
*.tmp
*.temp
.cache/
.temp/
tmp/

# ============================================
# OS specific
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================
# Application specific
# ============================================
# Token files (sensitive)
**/token.txt
**/error_token.txt
**/tokens.enc

# Cache directories
**/pow_config_cache/
**/.cache/

# Python embedded (large, should be downloaded)
python-embed/

# User data
%APPDATA%/spike/

# ============================================
# Development files
# ============================================
*.md.backup
*.bak
.scratch/
scratch/
test-results/
coverage/

# ============================================
# Git specific
# ============================================
*.orig
*.rej
.git/

# ============================================
# Documentation builds
# ============================================
docs/_build/
docs/.doctrees/

# ============================================
# Miscellaneous
# ============================================
*.zip
*.tar.gz
*.rar
*.7z
